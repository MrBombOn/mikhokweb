{
  "name": "hok-web-v11",
  "version": "1.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/MrBombOn/mikhokweb.git"
  },
  "bugs": {
    "url": "https://github.com/MrBombOn/mikhokweb/issues"
  },
  "homepage": "https://github.com/MrBombOn/mikhokweb#readme",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:prod-smoke": "playwright test --config=playwright.production.config.ts",
    "ops:dependency-risk": "node scripts/ops/dependency-risk-dashboard.cjs",
    "ops:generate-changelog": "node scripts/ops/generate-changelog.cjs",
    "ops:audit-export-alerts": "node scripts/ops/audit-export-alerts.cjs",
    "postinstall": "node scripts/prisma-env.cjs generate",
    "db:generate": "node scripts/prisma-env.cjs generate",
    "db:migrate": "node scripts/prisma-env.cjs migrate dev",
    "db:push": "node scripts/prisma-env.cjs db push",
    "db:studio": "node scripts/prisma-env.cjs studio",
    "db:seed": "node scripts/prisma-env.cjs db seed",
    "start:dev:ps1": "powershell -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1",
    "start:dev:test": "cmd /c scripts\\start-dev-test.bat",
    "start:prod:ps1": "powershell -ExecutionPolicy Bypass -File ./scripts/start-prod.ps1",
    "lhci": "lhci autorun",
    "ops:backup-drill": "node scripts/ops/backup-restore-drill.cjs",
    "ops:health-check": "node scripts/ops/system-check.cjs",
    "ops:smoke-gate": "node scripts/ops/post-deploy-smoke.cjs",
    "ops:release-checklist": "node scripts/ops/release-checklist-gate.cjs",
    "ops:retention-prune": "node scripts/ops/retention-prune.cjs",
    "ops:rebuild-search-index": "npx tsx scripts/ops/rebuild-search-index.ts",
    "ops:s3-upload-inventory": "npx tsx scripts/ops/s3-upload-inventory.ts",
    "ops:audit-report": "node scripts/ops/npm-audit-report.cjs",
    "ops:sbom": "node scripts/ops/npm-sbom.cjs"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@prisma/client": "^6.19.0",
    "@sentry/nextjs": "^9.47.1",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "next": "15.5.15",
    "nodemailer": "^8.0.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.51.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.50",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.25.1",
    "eslint-config-next": "15.5.15",
    "prisma": "^6.19.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
