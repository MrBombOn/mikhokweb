// Fázis 1: minimális felhasználói modell (Office / Admin). A Guest nem tárolt felhasználó.
// SQLite fejlesztői bootstrap; élesben PostgreSQL + ugyanez a séma (datasource URL .env-ből).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OFFICE
  ADMIN
}

enum CategoryScope {
  news
  events
  gallery
  guides
  office
}

enum FeedbackStatus {
  new
  in_progress
  closed
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(OFFICE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  calculatorState CalculatorState?
  auditLogs       AuditLog[]
  assignedFeedbacks FeedbackSubmission[] @relation("UserToFeedbackSubmission")
  savedTableViews AdminSavedView[]
  staffNotifications StaffNotification[]
}

/** P8: belső értesítések (in-app + opcionális webhook/email diszpécser). */
model StaffNotification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventKey  String
  severity  String    @default("info")
  titleHu   String
  titleEn   String
  bodyHu    String    @default("")
  bodyEn    String    @default("")
  meta      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

/** P7: mentett admin tábla nézetek (szűrők / lapozás) felhasználónként. */
model AdminSavedView {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module    String
  name      String
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, module])
}

enum ContentStatus {
  draft
  scheduled
  published
  archived
  deleted
}

enum NewsSource {
  internal
  facebook
  instagram
}

model News {
  id           Int           @id @default(autoincrement())
  source       NewsSource    @default(internal)
  category     String
  status       ContentStatus @default(draft)
  pinned       Boolean       @default(false)
  listDate     String
  titleHu      String
  titleEn      String
  textHu       String
  textEn       String
  author       String
  cover        String        @default("blue")
  hasCover     Boolean       @default(true)
  /** URL-barát azonosító; `null` = még nincs kiosztva. */
  slug         String?       @unique
  /** Nyilvános feed-ből számolt dedupe ujjlenyomat (FB/IG). */
  ingestFingerprint String?
  /** Előnézeti link token (egyszeri URL). */
  previewToken String?       @unique
  coverAltHu   String        @default("")
  coverAltEn   String        @default("")
  scheduledFor String?
  externalUrl  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  revisions    NewsRevision[]

  @@index([status, listDate])
  @@index([ingestFingerprint])
}

/** P1: hír módosítások története (snapshot JSON). */
model NewsRevision {
  id        Int      @id @default(autoincrement())
  newsId    Int
  news      News     @relation(fields: [newsId], references: [id], onDelete: Cascade)
  payload   Json
  editorId  String?
  createdAt DateTime @default(now())

  @@index([newsId, createdAt])
}

/** P1: külső feed dedupe – egy fingerprint legfeljebb egy élő hírhez kötve. */
model NewsIngestFingerprint {
  id           Int        @id @default(autoincrement())
  fingerprint  String     @unique
  source       NewsSource
  sourcePostId String?
  newsId       Int?
  createdAt    DateTime   @default(now())
}

enum BookingStatus {
  pending
  approved
  rejected
}

/** Naptár események (§11) – vendégnek csak `published`. */
model CalendarEvent {
  id        Int           @id @default(autoincrement())
  titleHu   String
  titleEn   String
  eventDate String
  time      String
  location  String
  category  String
  dayLabel  String?
  note      String?
  status    ContentStatus @default(published)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status, eventDate])
}

/** Tornaterem foglalási igények. */
model GymBooking {
  id             Int           @id @default(autoincrement())
  title          String        @default("Tornaterem foglalás")
  applicantName  String
  email          String
  organization   String?
  bookingDate    String
  startTime      String
  endTime        String
  purpose        String
  /** Email értesítések nyelve (HU/EN) – a foglaláskor rögzül, státuszváltásnál ez alapján küldünk. */
  notificationLocale String    @default("hu")
  status         BookingStatus @default(pending)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, bookingDate])
}

/** KKI kalkulátor mentett állapot – egy aktív snapshot / felhasználó (§12). */
model CalculatorState {
  userId    String   @id
  semesters Json
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/** Galéria mappa / album (§13). */
model GalleryFolder {
  id        Int           @id @default(autoincrement())
  name      String
  sortOrder Int           @default(0)
  items     GalleryItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

/** Galéria kép meta – `imageUrl` lehet üres (UI gradiens); különben letöltés / megjelenítés. */
model GalleryItem {
  id        Int           @id @default(autoincrement())
  folderId  Int
  folder    GalleryFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  titleHu   String
  titleEn   String
  listDate  String
  imageUrl  String        @default("")
  thumbnailUrl String     @default("")
  imageWidth Int?
  imageHeight Int?
  mimeType String?
  fileSizeBytes Int?
  exifJson Json?
  status    ContentStatus @default(published)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([folderId, status])
}

/** Útmutató / tudásbázis bejegyzés (§14). */
model Guide {
  id           Int           @id @default(autoincrement())
  titleHu      String
  titleEn      String
  excerptHu    String        @default("")
  excerptEn    String        @default("")
  bodyHu       String        @default("")
  bodyEn       String        @default("")
  category     String        @default("Általános")
  topic        String        @default("")
  keywords     String        @default("")
  documentUrl  String?
  documentType String?
  attachmentName String?
  attachmentMime String?
  attachmentSizeBytes Int?
  searchableText String @default("")
  listDate     String
  status       ContentStatus @default(published)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  revisions    GuideRevision[]

  @@index([status, listDate])
  @@index([status, category, topic])
}

/** Guide verziózás: minden szerkesztéskor snapshot a tartalomról (Fázis 3). */
model GuideRevision {
  id        Int      @id @default(autoincrement())
  guideId   Int
  guide     Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  version   Int
  payloadJson Json
  createdAt DateTime @default(now())

  @@unique([guideId, version])
  @@index([guideId, createdAt])
}

/** About oldal szöveges blokk (bemutatkozás, szerkezet, történet, kihez forduljak) – §15. */
model AboutNarrative {
  id        Int           @id @default(autoincrement())
  blockKey  String        @unique
  titleHu   String
  titleEn   String
  bodyHu    String        @default("")
  bodyEn    String        @default("")
  sortOrder Int           @default(0)
  status    ContentStatus @default(published)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status, sortOrder])
}

/** About oldal szerepkör / tag kártya – §15.1. */
model AboutMember {
  id        Int           @id @default(autoincrement())
  name      String
  roleHu    String
  roleEn    String
  bioHu     String        @default("")
  bioEn     String        @default("")
  groupHu   String        @default("")
  groupEn   String        @default("")
  imageUrl  String        @default("")
  /** P8: opcionális „megjelenés / mandátum” dátum (YYYY-MM-DD), csak megjelenítéshez. */
  publishedAt String?
  /** P8: alumni jelölés – külön szekcióba sorolás a csoportnév-heurisztika mellett. */
  isAlumni  Boolean       @default(false)
  sortOrder Int           @default(0)
  status    ContentStatus @default(published)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status, sortOrder])
}

/** Office oldal összesített állapota (§16): nyitvatartás, bent lévők, ügyintézés, szolgáltatás infó. */
model OfficeSnapshot {
  id              Int           @id
  openingHoursHu  String
  openingHoursEn  String
  /** P8: heti bontás (szabad szöveg) – a „ma” sor kiemeléséhez használható. */
  weeklyScheduleHu String       @default("")
  weeklyScheduleEn String       @default("")
  presentNowHu    String        @default("")
  presentNowEn    String        @default("")
  serviceStatusHu String
  serviceStatusEn String
  servicesInfoHu  String        @default("")
  servicesInfoEn  String        @default("")
  nfcInfoHu       String        @default("")
  nfcInfoEn       String        @default("")
  quickInfoHu     String        @default("")
  quickInfoEn     String        @default("")
  /** P8: csak OFFICE/ADMIN – vendég API válaszból kiszűrve. */
  internalNoteHu  String        @default("")
  internalNoteEn  String        @default("")
  status          ContentStatus @default(published)
  updatedAt       DateTime      @updatedAt
}

/** Kategória SSOT admin kezeléshez (§17, §19). */
model Category {
  id        Int           @id @default(autoincrement())
  scope     CategoryScope
  nameHu    String
  nameEn    String
  sortOrder Int           @default(0)
  status    ContentStatus @default(published)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([scope, status])
}

/** Nyilvános visszajelzés űrlap beküldései (`POST /api/feedback`) – perzisztens napló. */
model FeedbackSubmission {
  id        String   @id @default(cuid())
  module    String
  message   String
  email     String?
  status    FeedbackStatus @default(new)
  assigneeId String?
  assignee   User?    @relation("UserToFeedbackSubmission", fields: [assigneeId], references: [id], onDelete: SetNull)
  internalNote String @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([module])
  @@index([status, createdAt])
  @@index([assigneeId])
}

/** Admin audit események – érzékeny írási műveletek naplója (§17, §21). */
model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorName  String
  actorRole  String
  action     String
  entityType String
  entityId   String
  details    String   @default("")
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
}

/** Admin Studio: egyedi publikus oldalak (slug + struktúrált tartalom JSON). */
model SiteBuilderPage {
  id        Int           @id @default(autoincrement())
  slug      String        @unique
  titleHu   String
  titleEn   String
  bodyJson  Json
  status    ContentStatus @default(draft)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  revisions SiteBuilderPageRevision[]
  publishQueue SiteBuilderPublishQueue[]

  @@index([status, slug])
}

/** Builder Studio V2: szerkesztési snapshotok (diff/rollback). */
model SiteBuilderPageRevision {
  id        Int      @id @default(autoincrement())
  pageId    Int
  page      SiteBuilderPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  action    String   @default("patch")
  titleHu   String
  titleEn   String
  bodyJson  Json
  status    ContentStatus
  actorId   String?
  createdAt DateTime @default(now())

  @@index([pageId, createdAt])
}

/** Builder Studio V2: publikálási queue és feldolgozási állapot. */
model SiteBuilderPublishQueue {
  id          Int      @id @default(autoincrement())
  pageId       Int
  page         SiteBuilderPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  targetStatus ContentStatus @default(published)
  scheduledFor DateTime?
  status       String   @default("queued")
  processedAt  DateTime?
  createdAt    DateTime @default(now())
  createdById  String?

  @@index([status, scheduledFor])
  @@index([pageId, createdAt])
}

/** Admin Studio: globális design beállítások singleton rekordban. */
model SiteDesignConfig {
  id             Int      @id
  primaryColor   String   @default("#3b82f6")
  accentColor    String   @default("#ec4899")
  surfaceRadius  Int      @default(16)
  contentMaxWidth Int     @default(1100)
  fontFamily     String   @default("Inter, system-ui, sans-serif")
  customCss      String   @default("")
  updatedAt      DateTime @updatedAt
}

/** Release governance: log/adat megőrzési idő (nap) singleton rekordban. */
model RetentionConfig {
  id             Int      @id
  auditLogDays   Int      @default(365)
  feedbackDays   Int      @default(365)
  requestLogDays Int      @default(30)
  updatedAt      DateTime @updatedAt
}

/** §12 Fázis 14: központi publikus keresőindex (news / events / guides), szerveroldali lekérdezéshez. */
model SearchDocument {
  id         String   @id @default(cuid())
  module     String
  entityId   Int
  titleHu    String
  titleEn    String
  snippetHu  String   @default("")
  snippetEn  String   @default("")
  /** Normalizált (kisbetűs) egyesített szöveg – `LIKE` / `ILIKE` illesztéshez. */
  searchBlob String
  category   String   @default("")
  slug       String?
  hrefPath   String
  listDate   String   @default("")
  updatedAt  DateTime @updatedAt

  @@unique([module, entityId])
  @@index([module])
  @@index([category])
}

/**
 * Anonim keresési aggregátum: napi bontás + max 120 karakteres normalizált lekérdezés (e-mail minták kiszűrve).
 */
model SearchQueryStat {
  id               String @id @default(cuid())
  day              String
  queryNormalized  String
  searchCount      Int    @default(0)
  zeroResultCount  Int    @default(0)

  @@unique([day, queryNormalized])
  @@index([day])
}
