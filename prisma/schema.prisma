// Fázis 1: minimális felhasználói modell (Office / Admin). A Guest nem tárolt felhasználó.
// SQLite fejlesztői bootstrap; élesben PostgreSQL + ugyanez a séma (datasource URL .env-ből).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OFFICE
  ADMIN
}

enum CategoryScope {
  news
  events
  gallery
  guides
  office
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(OFFICE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  calculatorState CalculatorState?
}

enum ContentStatus {
  draft
  scheduled
  published
  archived
  deleted
}

enum NewsSource {
  internal
  facebook
  instagram
}

model News {
  id           Int           @id @default(autoincrement())
  source       NewsSource    @default(internal)
  category     String
  status       ContentStatus @default(draft)
  pinned       Boolean       @default(false)
  listDate     String
  titleHu      String
  titleEn      String
  textHu       String
  textEn       String
  author       String
  cover        String        @default("blue")
  hasCover     Boolean       @default(true)
  scheduledFor String?
  externalUrl  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum BookingStatus {
  pending
  approved
  rejected
}

/** Naptár események (§11) – vendégnek csak `published`. */
model CalendarEvent {
  id        Int           @id @default(autoincrement())
  titleHu   String
  titleEn   String
  eventDate String
  time      String
  location  String
  category  String
  dayLabel  String?
  note      String?
  status    ContentStatus @default(published)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

/** Tornaterem foglalási igények. */
model GymBooking {
  id             Int           @id @default(autoincrement())
  title          String        @default("Tornaterem foglalás")
  applicantName  String
  email          String
  organization   String?
  bookingDate    String
  startTime      String
  endTime        String
  purpose        String
  status         BookingStatus @default(pending)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

/** KKI kalkulátor mentett állapot – egy aktív snapshot / felhasználó (§12). */
model CalculatorState {
  userId    String   @id
  semesters Json
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/** Galéria mappa / album (§13). */
model GalleryFolder {
  id        Int           @id @default(autoincrement())
  name      String
  sortOrder Int           @default(0)
  items     GalleryItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

/** Galéria kép meta – `imageUrl` lehet üres (UI gradiens); különben letöltés / megjelenítés. */
model GalleryItem {
  id        Int           @id @default(autoincrement())
  folderId  Int
  folder    GalleryFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  titleHu   String
  titleEn   String
  listDate  String
  imageUrl  String        @default("")
  status    ContentStatus @default(published)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

/** Útmutató / tudásbázis bejegyzés (§14). */
model Guide {
  id           Int           @id @default(autoincrement())
  titleHu      String
  titleEn      String
  excerptHu    String        @default("")
  excerptEn    String        @default("")
  bodyHu       String        @default("")
  bodyEn       String        @default("")
  category     String        @default("Általános")
  topic        String        @default("")
  keywords     String        @default("")
  documentUrl  String?
  documentType String?
  listDate     String
  status       ContentStatus @default(published)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

/** About oldal szöveges blokk (bemutatkozás, szerkezet, történet, kihez forduljak) – §15. */
model AboutNarrative {
  id        Int           @id @default(autoincrement())
  blockKey  String        @unique
  titleHu   String
  titleEn   String
  bodyHu    String        @default("")
  bodyEn    String        @default("")
  sortOrder Int           @default(0)
  status    ContentStatus @default(published)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

/** About oldal szerepkör / tag kártya – §15.1. */
model AboutMember {
  id        Int           @id @default(autoincrement())
  name      String
  roleHu    String
  roleEn    String
  bioHu     String        @default("")
  bioEn     String        @default("")
  groupHu   String        @default("")
  groupEn   String        @default("")
  imageUrl  String        @default("")
  sortOrder Int           @default(0)
  status    ContentStatus @default(published)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

/** Office oldal összesített állapota (§16): nyitvatartás, bent lévők, ügyintézés, szolgáltatás infó. */
model OfficeSnapshot {
  id              Int           @id
  openingHoursHu  String
  openingHoursEn  String
  presentNowHu    String        @default("")
  presentNowEn    String        @default("")
  serviceStatusHu String
  serviceStatusEn String
  servicesInfoHu  String        @default("")
  servicesInfoEn  String        @default("")
  nfcInfoHu       String        @default("")
  nfcInfoEn       String        @default("")
  quickInfoHu     String        @default("")
  quickInfoEn     String        @default("")
  status          ContentStatus @default(published)
  updatedAt       DateTime      @updatedAt
}

/** Kategória SSOT admin kezeléshez (§17, §19). */
model Category {
  id        Int           @id @default(autoincrement())
  scope     CategoryScope
  nameHu    String
  nameEn    String
  sortOrder Int           @default(0)
  status    ContentStatus @default(published)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

/** Admin audit események – érzékeny írási műveletek naplója (§17, §21). */
model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    String?
  actorName  String
  actorRole  String
  action     String
  entityType String
  entityId   String
  details    String   @default("")
  createdAt  DateTime @default(now())
}
