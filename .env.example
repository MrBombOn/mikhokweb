# Másolás fejlesztéshez: `copy .env.example .env.local` (Windows) vagy `cp .env.example .env.local`
# A Prisma parancsok (`npm run db:migrate`, `db:seed`, stb.) a `scripts/prisma-env.cjs` miatt
# **betöltik a `.env.local`-t is** — nem kell külön `.env` csak a DATABASE_URL miatt.
# Ne commitolj valódi titkokat.

# Database – fejlesztéshez SQLite. Gyakori: `file:./dev.db` (repo gyökér) vagy `file:./prisma/dev.db` — a fájl helye és a DATABASE_URL egyezzen.
DATABASE_URL="file:./dev.db"

# JWT session aláírás (HS256). Minimum 32 karakter. Productionban kötelező.
# Fejlesztésben, ha üres: beépített dev fallback (ne használd élesben).
AUTH_SECRET="change-me-to-at-least-32-characters!!"

# Seed felhasználók (`npm run db:seed`) – csak fejlesztői környezetben futtasd ellenőrzött jelszavakkal.
# SEED_ADMIN_USERNAME="admin"
# SEED_ADMIN_PASSWORD="..."
# SEED_OFFICE_USERNAME="office"
# SEED_OFFICE_PASSWORD="..."

# Demó tartalom API hiba esetén (Fázis 6). Production: alapból ki; csak staging demóhoz: "1"
# Fejlesztésben kikapcsolás (pl. E2E): "0"
# ALLOW_DEMO_FALLBACK="0"

# P2: Visszajelzés CAPTCHA (Cloudflare Turnstile) — ha a secret be van állítva, a szerver kötelezővé teszi a tokent.
# A kereső (/search) űrlap megjeleníti a widgetet a NEXT_PUBLIC_* kulccsal.
# FEEDBACK_TURNSTILE_SECRET_KEY=""
# NEXT_PUBLIC_FEEDBACK_TURNSTILE_SITE_KEY=""

# P5: opcionális booking értesítés webhook (új foglalás létrejöttekor szerver oldali POST JSON).
# A webhook és az SMTP egymástól független: webhook nélkül is megy az email, ha SMTP be van állítva.
# BOOKING_NOTIFY_WEBHOOK_URL=""

# P5/F1: booking email értesítések (SMTP) -- ha BOOKING_EMAIL_ENABLED="1", a rendszer emailt is küld
# foglalás létrejöttekkor és státuszváltáskor (nyelv: kliens `locale` mező / `notificationLocale` DB).
# BOOKING_EMAIL_ENABLED="0"
# BOOKING_EMAIL_FROM="noreply@example.com"
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="smtp-user"
# SMTP_PASS="smtp-password"
# SMTP_FROM="noreply@example.com"

# P3: opcionális feedback értesítés webhook (új visszajelzés létrejöttekor szerver oldali POST JSON).
# FEEDBACK_NOTIFY_WEBHOOK_URL=""

# P8 / Fázis 8: staff értesítések (bulk import, audit export, feature flag) – webhook + opcionális SMTP broadcast.
# STAFF_NOTIFY_WEBHOOK_URL=""
# STAFF_NOTIFY_EMAIL_ENABLED="0"
# STAFF_NOTIFY_EMAIL_TO="ops@example.com"
# (SMTP mezők: lásd BOOKING/foglalás példa fent – `SMTP_HOST`, `SMTP_PORT`, `SMTP_USER`, `SMTP_PASS`, `SMTP_FROM`)

# §12 Fázis 15: objektumtár (S3-kompatibilis) vs helyi `public/uploads`
# STORAGE_DRIVER="local"   # alap; élesben: "s3"
# S3_BUCKET=""
# S3_REGION="eu-central-1"
# S3_PUBLIC_BASE_URL="https://cdn.pelda.hu"   # böngésző URL prefix (nincs trailing /)
# S3_ACCESS_KEY_ID=""   # vagy AWS_ACCESS_KEY_ID
# S3_SECRET_ACCESS_KEY=""   # vagy AWS_SECRET_ACCESS_KEY
# S3_ENDPOINT=""        # MinIO / R2: pl. https://xxx.r2.cloudflarestorage.com
# S3_FORCE_PATH_STYLE="1"
# Opcionális: feltöltés utáni scan hook (nem blokkol)
# UPLOAD_SCAN_WEBHOOK_URL=""
# next/image: ha a kliensen is kell host felismerés, állítsd a NEXT_PUBLIC_S3_PUBLIC_BASE_URL-t vagy NEXT_PUBLIC_IMAGE_REMOTE_HOSTS-ot
# NEXT_PUBLIC_S3_PUBLIC_BASE_URL="https://cdn.pelda.hu"

# Fázis 13: további `next/image` remote hostok (vesszővel; aldomén: `*.cdn.example.com`)
# Build újra a `next.config.ts` `remotePatterns` frissítéséhez.
# NEXT_PUBLIC_IMAGE_REMOTE_HOSTS="cdn.example.com,*.r2.cloudflarestorage.com"

# Fázis 5 / P9: backup drill + health check (lásd docs/backup-restore-drill.md, scheduled-health-routine.md)
# BACKUP_DRILL_DIR=".ops/backup-drill"
# BACKUP_DRILL_MODE="light"
# BACKUP_DRILL_RESTORE_URL="postgresql://user:pass@host:5432/empty_drill_db"
# HEALTHCHECK_URL="https://pelda.hu/api/health"
# HEALTHCHECK_TIMEOUT_MS="15000"
# SMOKE_PORT="3300"
# SMOKE_TIMEOUT_MS="90000"

# Fázis 12: retention batch — lejárt audit + feedback sorok törlése (lásd docs/privacy-and-gdpr.md).
# RETENTION_PRUNE_DRY_RUN="1"  # csak számolás, nem törlés

# Fázis 6 / P10: release governance gate (CI-ben javasolt bekapcsolva).
# FF_LIGHTHOUSE_CI_GATE="1"

# P10: Site Builder V2 canary (master flag + rollout %; hash bucket felhasználó ID alapján).
# FF_SITE_BUILDER_V2_CANARY="1"
# FF_SITE_BUILDER_V2_CANARY_ROLLOUT="100"

# P10: Playwright E2E (opcionális; alapértelmezés a seed jelszavak).
# E2E_ADMIN_USERNAME="admin"
# E2E_ADMIN_PASSWORD="admin-dev-change-me"
# E2E_OFFICE_USERNAME="office"
# E2E_OFFICE_PASSWORD="office-dev-change-me"
# PLAYWRIGHT_BASE_URL="http://127.0.0.1:3000"
# E2E_ALLOW_HTTP_COOKIES="1"  # csak Playwright webServer (playwright.config) állítja; ne élesben.

# §12 Fázis 17: éles / staging publikus Playwright smoke (`npm run test:e2e:prod-smoke`, lásd docs/synthetic-monitoring.md)
# PRODUCTION_SMOKE_BASE_URL="https://portal.example.hu"

# §12 Fázis 16: CycloneDX SBOM (lokálisan `.ops/sbom.cdx.json`, lásd docs/security-supply-chain.md)
# npm run ops:sbom

# §12 Fázis 19: partner read API (`GET /api/v1/public/feed`) — min. 16 karakter; fejléc `X-Hok-Public-Api-Key` vagy `Authorization: Bearer`
# PUBLIC_READ_API_KEY=""

# P10: audit export batch riasztás (ops:audit-export-alerts).
# AUDIT_EXPORT_ALERT_WINDOW_HOURS="24"
# AUDIT_EXPORT_ALERT_COUNT="3"

# Fázis 4 / P9: Sentry (opcionális). Szerver: SENTRY_DSN; böngésző SDK: NEXT_PUBLIC_SENTRY_DSN.
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_ENVIRONMENT="production"
# NEXT_PUBLIC_SENTRY_ENVIRONMENT="production"
