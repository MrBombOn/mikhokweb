# Copy to `.env.local` for local development. Do not commit real values.

# Database – fejlesztéshez SQLite (fájl a prisma mappában). Éles: PostgreSQL URL.
DATABASE_URL="file:./dev.db"

# JWT session aláírás (HS256). Minimum 32 karakter. Productionban kötelező.
# Fejlesztésben, ha üres: beépített dev fallback (ne használd élesben).
AUTH_SECRET="change-me-to-at-least-32-characters!!"

# Seed felhasználók (`npm run db:seed`) – csak fejlesztői környezetben futtasd ellenőrzött jelszavakkal.
# SEED_ADMIN_USERNAME="admin"
# SEED_ADMIN_PASSWORD="..."
# SEED_OFFICE_USERNAME="office"
# SEED_OFFICE_PASSWORD="..."

# Optional: file uploads / CDN (future)
# STORAGE_BUCKET=""
# STORAGE_REGION=""
